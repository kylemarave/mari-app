# Google Gemini — required for AI PDF → study set generation (server-side only)
GEMINI_API_KEY=

# Supabase Auth (client — Angular exposes NG_APP_* vars at build time)
NG_APP_SUPABASE_URL=
NG_APP_SUPABASE_ANON_KEY=

# Supabase server (API gating — NEVER expose service role to client)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Same anon values as above (for reference / CI scripts)
SUPABASE_ANON_KEY=

# Dev API server (optional, for ng serve with proxy)
DEV_API_PORT=3001

# --- Stripe (optional — enable when Pro billing is ready) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID_PRO=
# APP_URL=

# When Stripe is configured, set STRIPE_BILLING_ENABLED = true in
# src/app/core/config/features.ts and add the vars above.
