# Google Gemini — required for AI PDF → study set generation (server-side only)
GEMINI_API_KEY=

# Supabase Auth (client — Angular exposes NG_APP_* vars at build time)
NG_APP_SUPABASE_URL=
NG_APP_SUPABASE_ANON_KEY=

# Same values as above (for reference / CI scripts; map to NG_APP_* in Vercel)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Dev API server (optional, for ng serve with proxy)
DEV_API_PORT=3001
