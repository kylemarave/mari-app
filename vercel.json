{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/mari-app/browser",
  "framework": null,
  "rewrites": [
    {
      "source": "/",
      "destination": "/api"
    },
    {
      "source": "/((?!.*\\.).*)",
      "destination": "/api"
    }
  ],
  "functions": {
    "api/index.mjs": {
      "includeFiles": "dist/mari-app/**",
      "maxDuration": 60
    }
  }
}
